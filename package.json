{
  "name": "pancake-pos-mcp",
  "version": "0.1.0",
  "description": "MCP server wrapping Pancake POS REST API for AI assistant and automation integration",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run src/index.ts",
    "start:stdio": "bun run src/index.ts --stdio",
    "start:http": "bun run src/index.ts --http",
    "typecheck": "bun run --bun tsc --noEmit",
    "dev:workers": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.3",
    "@cloudflare/workers-types": "^4.20260410.1",
    "@types/bun": "latest",
    "@types/json-mask": "^2.0.3",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "json-mask": "^2.0.0",
    "zod": "^4.3.6"
  }
}
