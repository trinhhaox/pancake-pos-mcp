# Pancake POS API credentials
PANCAKE_POS_API_KEY=your_api_key_here
PANCAKE_POS_SHOP_ID=your_shop_id_here

# Optional: override base URL (default: https://pos.pages.fm/api/v1)
# PANCAKE_POS_BASE_URL=https://pos.pages.fm/api/v1

# HTTP transport port (default: 3000)
# PORT=3000

# Bearer token for HTTP / Cloudflare Workers transports (recommended for production).
# When set, /mcp requires `Authorization: Bearer <token>`. Leave unset to disable auth.
# Generate with: openssl rand -hex 32
MCP_AUTH_TOKEN=your_secret_token_here
